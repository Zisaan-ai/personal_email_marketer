# Phusion Passenger setup for cPanel
# DO NOT REMOVE. cPanel needs this.
PassengerAppRoot "/home/yourusername/personal_email_marketer"
PassengerBaseURI "/"
PassengerPython "/home/yourusername/virtualenv/personal_email_marketer/3.10/bin/python"

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Force HTTPS (optional, uncomment to use)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>


# restart